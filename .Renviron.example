# ============================================
# AISDK Project Environment Variables Template (.Renviron)
# ============================================
# Copy this file to .Renviron and fill in your actual API keys
# NEVER commit .Renviron to version control
#
# To create .Renviron from this template, run:
#   usethis::edit_r_environ(scope = "project")
# Then copy the contents below into the file
#
# After editing .Renviron, restart your R session for changes to take effect
# ============================================

# --- OpenAI ---
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# --- Anthropic ---
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"
ANTHROPIC_BASE_URL="https://api.anthropic.com"

# --- Google Gemini ---
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-pro"

# --- DeepSeek ---
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# --- Stepfun (阶跃星辰) ---
STEPFUN_API_KEY=""
STEPFUN_MODEL="step-1-8k"

# --- Volcengine Ark (火山引擎/火山方舟) ---
ARK_API_KEY=""
ARK_MODEL="" # Your endpoint ID
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"

# --- Alibaba Cloud Bailian (阿里云百炼/DashScope) ---
DASHSCOPE_API_KEY=""
DASHSCOPE_MODEL="qwen-plus"
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# --- NVIDIA (NIM) ---
NVIDIA_API_KEY=""
NVIDIA_MODEL="meta/llama-3.1-405b-instruct"

# --- xAI (Grok) ---
XAI_API_KEY=""
XAI_MODEL="grok-2-1212"
XAI_BASE_URL="https://api.x.ai/v1"

# --- OpenRouter ---
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"

# --- Custom Provider Example ---
# CUSTOM_PROVIDER_NAME="my-proxy"
# CUSTOM_PROVIDER_BASE_URL="https://my-proxy.com/v1"
