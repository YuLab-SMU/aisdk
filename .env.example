# ============================================
# AISDK Project Environment Variables (.env format)
# ============================================
# Alternative to .Renviron using the dotenv package format
# This format is compatible with Python, Node.js, and other languages
#
# To use this format:
# 1. Copy this file to .env
# 2. Install dotenv package: install.packages("dotenv")
# 3. Load in R: dotenv::load_dot_env()
# 4. Use keys via Sys.getenv()
#
# After editing .env, run: dotenv::load_dot_env() to reload
# ============================================

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o # gpt-4o, gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest # claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022
ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro # gemini-1.5-pro, gemini-1.5-flash

# --- DeepSeek ---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat # deepseek-chat, deepseek-reasoner
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Stepfun (阶跃星辰) ---
STEPFUN_API_KEY=
STEPFUN_MODEL=step-1-8k # step-1-8k, step-1-200k, step-1-flash

# --- Volcengine Ark (火山引擎/火山方舟) ---
ARK_API_KEY=
ARK_MODEL= # Your endpoint ID
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# --- Alibaba Cloud Bailian (阿里云百炼/DashScope) ---
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus # qwen-plus, qwen-turbo, qwen-max
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- NVIDIA (NIM) ---
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-405b-instruct # Example model ID

# --- xAI (Grok) ---
XAI_API_KEY=
XAI_MODEL=grok-2-1212
XAI_BASE_URL=https://api.x.ai/v1

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Custom Provider Example ---
# CUSTOM_PROVIDER_NAME=my-proxy
# CUSTOM_PROVIDER_BASE_URL=https://my-proxy.com/v1
# CUSTOM_PROVIDER_API_KEY=sk-...
# CUSTOM_PROVIDER_FORMAT=chat_completions # chat_completions, responses, anthropic_messages

# Optional: Enable/disable API tests
# ENABLE_API_TESTS=TRUE
